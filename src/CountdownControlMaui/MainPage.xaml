<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="CountdownControlMaui.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CountdownControlMaui.Controls">

    <Grid Padding="12"
          RowDefinitions="Auto,Auto,Auto,*,Auto"
          RowSpacing="12">

        <controls:CountdownControl x:Name="MyCountdown"
                                   Grid.Row="0"
                                   HeightRequest="200"
                                   WidthRequest="200"
                                   Duration="00:00:30" />

        <controls:CountdownControl x:Name="MyCountdown2"
                                   Grid.Row="1"
                                   ActiveColor="Blue"
                                   HeightRequest="100"
                                   InactiveColor="Yellow"
                                   TextColor="LightGray"
                                   WidthRequest="100"
                                   Duration="00:00:30" />

        <controls:CountdownControl x:Name="MyCountdown3"
                                   Grid.Row="2"
                                   ActiveColor="Black"
                                   HeightRequest="50"
                                   InactiveColor="DarkGray"
                                   TextColor="SteelBlue"
                                   WidthRequest="50"
                                   Duration="00:00:30" />

        <Button Grid.Row="4"
                Clicked="OnStartCountdownButtonClicked"
                HorizontalOptions="Fill"
                Text="Start Countdown" />

    </Grid>

</ContentPage>
